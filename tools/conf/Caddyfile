# Main blog domain
progrunning.net, www.progrunning.net {
    reverse_proxy ghost:2368 {
        header_uri -X-Forwarded-Proto https
        header_uri -X-Forwarded-Host progrunning.net
    }
}

# Arcane service (Docker container manager)
arcane.progrunning.net {
    reverse_proxy arcane:3552 {
        header_uri -X-Forwarded-Proto https
        header_uri -X-Forwarded-Host arcane.progrunning.net
    }
}

# Grafana service (Monitoring & Visualization)
grafana.progrunning.net {
    basicauth / {
        {$GRAFANA_USER} {$GRAFANA_PASSWORD_HASH}
    }
    reverse_proxy grafana:3000 {
        header_uri -X-Forwarded-Proto https
        header_uri -X-Forwarded-Host grafana.progrunning.net
    }
}

# Beszel service (System Monitoring)
beszel.progrunning.net {
    basicauth / {
        {$BESZEL_USER} {$BESZEL_PASSWORD_HASH}
    }
    reverse_proxy beszel:8090 {
        header_uri -X-Forwarded-Proto https
        header_uri -X-Forwarded-Host beszel.progrunning.net
    }
}

# Caddy admin API (optional, for management)
admin.progrunning.net {
    basicauth / {
        {$CADDY_ADMIN_USER} {$CADDY_ADMIN_PASSWORD_HASH}
    }
    reverse_proxy localhost:2019
}
